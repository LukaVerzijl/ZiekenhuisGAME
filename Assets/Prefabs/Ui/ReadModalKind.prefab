  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Binnenkort ga je iets heel bijzonders doen: je krijgt een MRI-scan! \n\nDat
    klinkt\nmisschien een beetje spannend, maar eigenlijk is het een soort grote
    camera. Deze\ncamera maakt geen foto\u2019s van je glimlach, maar kan dwars door
    je buik of je hoofd\nkijken om te zien of alles daar goed gaat.\n\nHoe werkt
    het?\nDe camera ziet eruit als een grote, verlichte tunnel. Je mag op een speciaal
    bed\ngaan liggen dat langzaam de tunnel in schuift. De tunnel is aan beide kanten
    open,\ndus er komt altijd frisse lucht bij je.\nStilzitten als een standbeeld\nOm
    de mooiste foto\u2019s te maken, is \xE9\xE9n ding heel belangrijk. Je moet namelijk
    heel\ngoed stil blijven liggen, net als een standbeeld. Als je wiebelt, worden
    de foto\u2019s wazig\nen dan kunnen de artsen hem niet goed bekijken.\n\nEen
    concert van klopjes\nWanneer de camera de foto's maakt, hoor je harde geluiden.
    Die zijn misschien niet\nzo fijn om naar te luisteren. Gelukkig krijg je een
    koptelefoon op waar je naar je\neigen lievelingsmuziek of een spannend verhaal
    kunt luisteren. Zo hoor je de herrie\nbijna niet meer!\n\nAltijd dichtbij\nDe
    dokter staat in de kamer ernaast en kan je de hele tijd zien door een raam. Je\nkrijgt
    een belletje in je hand. Als je daar in knijpt, hoort de dokter dat meteen en
    komt\nhij of zij naar je toe. Je bent dus nooit echt alleen!\n\nEn klaar!\nAls
    de camera klaar is met klikken, schuif je weer naar buiten. Je hoeft niet te\nwachten
    op de foto\u2019s, die moeten eerst nog even goed bekeken worden door de\ndokters.
    Je mag na het onderzoek meteen weer spelen, eten en drinken.\n\nSucces met de
    MRI!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 191995d2d6a492e42bb45748ea15ac3b, type: 2}
  m_sharedMaterial: {fileID: -927621672973273426, guid: 191995d2d6a492e42bb45748ea15ac3b, type: 2}
